# algo_spy trail (loaded automatically from this folder on startup)
# ~0.20% arm — above round-trip commission breakeven (~0.17% at ~13 shares)
ALGO_SPY_TRAIL_ARM=0.002
ALGO_SPY_TRAIL_PCT=0.001
ALGO_SPY_TRAIL_MIN_HOLD_SEC=60

# No new 5m-bar entries at or after this ET time (default: 30 min before 16:00 close)
ALGO_SPY_ENTRY_CUTOFF_ET=15:30
# ALGO_SPY_NO_ENTRY_MINUTES_BEFORE_CLOSE=30

# breadth = score + subscore alignment (default); full = legacy EMA filter; off = pure breadth
ALGO_SPY_EMA_MODE=breadth

# 5m L1 push-pull flow folded into breadth score + medium subscore
ALGO_SPY_FLOW_MODE=score        # off | score
ALGO_SPY_FLOW_WEIGHT=0.5        # scales (buy_pct - sell_pct); max term ±50
ALGO_SPY_FLOW_EDGE=20           # deadzone: ignore splits inside ~60/40
ALGO_SPY_FLOW_MIN_EVENTS=10     # min classified 5m events before trusting flow

# Tape replay (saved under algo_spy/sessions/)
ALGO_SPY_RECORD_TAPE=1
# ALGO_SPY_TAPE_DIR=sessions
