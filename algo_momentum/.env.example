# algo_momentum trail / sizing (loaded automatically from this folder on startup)
# Trail arm above typical round-trip commission+slip breakeven on single names
ALGO_MOM_TRAIL_ARM=0.004
ALGO_MOM_TRAIL_PCT=0.002
ALGO_MOM_TRAIL_MIN_HOLD_SEC=60

# Portfolio controls
ALGO_MOM_MAX_POSITIONS=5
ALGO_MOM_CASH_FRACTION=0.20

# No new entries at or after this ET time
ALGO_MOM_ENTRY_CUTOFF_ET=15:30
